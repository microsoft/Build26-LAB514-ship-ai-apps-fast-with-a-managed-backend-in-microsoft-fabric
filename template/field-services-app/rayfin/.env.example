# Example Rayfin environment variables
# Copy this file to rayfin/.env and customize values for your environment.
# `rayfin dev` and `rayfin up` auto-populate most of these values.
# See docs/rfc/env-file-strategy.md for the full variable reference.

# ── Frontend-visible variables (RAYFIN_PUBLIC_*) ───────────────────────
# Mapped to framework-specific prefixes by `rayfin env --framework <fw>`.

# Rayfin API Base URL (written by `rayfin dev` / `rayfin up`)
RAYFIN_PUBLIC_API_URL=http://localhost:5168

# Rayfin Publishable Key (fetched by `rayfin dev` from the running webservice)
# RAYFIN_PUBLIC_PUBLISHABLE_KEY=pk-yourKeyHere

# ── Tooling overrides (not exposed to frontend) ────────────────────────

# Fabric environment overrides
# RAYFIN_FABRIC_API_URL=https://api.fabric.microsoft.com/v1
# RAYFIN_FABRIC_PORTAL_URL=https://app.fabric.microsoft.com/
